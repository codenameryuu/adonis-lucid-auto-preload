{
  "name": "@codenameryuu/adonis-lucid-auto-preload",
  "version": "1.4.0",
  "description": "Auto-preload multiple relationships when retrieving Lucid models on Adonis JS 7",
  "author": "codenameryuu",
  "license": "MIT",
  "homepage": "https://github.com/codenameryuu/adonis-lucid-auto-preload#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codenameryuu/adonis-lucid-auto-preload.git"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "files": [
    "build",
    "!build/bin",
    "!build/tests"
  ],
  "exports": {
    ".": "./build/index.js",
    "./adonis-typings": "./build/adonis-typings/*.js",
    "./exceptions": "./build/exceptions/*.js",
    "./providers": "./build/providers/auto_preload_provider.js"
  },
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "clean": "del-cli build",
    "precompile": "npm run lint && npm run clean",
    "compile": "tsup-node && tsc --emitDeclarationOnly --declaration",
    "build": "npm run compile",
    "pretest": "npm run lint",
    "test": "c8 npm run quick:test",
    "typecheck": "tsc --noEmit",
    "version": "npm run build",
    "prepublishOnly": "npm run build",
    "release": "np"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.7.0",
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/lucid": "^22.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/assert": "^4.2.0",
    "@japa/expect": "^3.0.7",
    "@japa/expect-type": "^2.0.4",
    "@japa/file-system": "^3.0.0",
    "@japa/runner": "^5.3.0",
    "@japa/snapshot": "^2.0.5",
    "@japa/spec-reporter": "^1.3.3",
    "@poppinss/dev-utils": "^2.0.3",
    "@types/node": "^25.5.0",
    "c8": "^9.1.0",
    "copyfiles": "^2.4.1",
    "del-cli": "^5.0.0",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "youch": "^4.1.0"
  },
  "peerDependencies": {
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/lucid": "^22.0.0"
  },
  "keywords": [
    "adonis",
    "adonisjs",
    "auto-preload"
  ],
  "prettier": "@adonisjs/prettier-config",
  "publishConfig": {
    "tag": "latest",
    "access": "public"
  },
  "np": {
    "message": "chore(release): %s",
    "tag": "latest",
    "branch": "main",
    "anyBranch": false
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "exclude": [
      "tests/**",
      "bin/**"
    ]
  },
  "tsup": {
    "entry": [
      "./index.ts",
      "./src/exceptions/*.ts",
      "./adonis-typings/*.ts",
      "./providers/auto_preload_provider.ts"
    ],
    "outDir": "./build",
    "clean": true,
    "format": "esm",
    "dts": false,
    "sourcemap": true,
    "target": "esnext"
  }
}
